rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "dearaujomarcos2@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'Admin')
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.nome is string && data.nome.size() > 0 && data.nome.size() < 100 &&
             data.email is string && data.email.size() > 0 &&
             data.tipo in ['Estudante', 'Admin'];
    }

    function isValidRequest(data) {
      return data.titulo is string && data.titulo.size() > 0 && data.titulo.size() < 200 &&
             data.descricao is string && data.descricao.size() > 0 && data.descricao.size() < 5000 &&
             data.status in ['Pendente', 'Em análise', 'Concluída'] &&
             data.prioridade in ['Baixa', 'Média', 'Alta'] &&
             data.categoria in ['Acadêmico', 'Financeiro', 'Secretaria', 'Outros'] &&
             data.usuarioId is string &&
             data.dataCriacao is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      // Split rules to ensure owner can always read even if isAdmin() fails (e.g. doc doesn't exist)
      allow read: if isOwner(userId);
      allow read: if isAdmin();
      // Allow authenticated users to read admin profiles (for notification purposes)
      allow read: if isAuthenticated() && resource.data.tipo == 'Admin';

      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.tipo == 'Estudante' || isAdmin());
      
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) &&
                    (request.resource.data.tipo == resource.data.tipo || isAdmin());
    }

    // Academic requests
    match /requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.usuarioId == request.auth.uid || isAdmin());
      
      allow create: if isAuthenticated() && isValidRequest(request.resource.data) && 
                    request.resource.data.usuarioId == request.auth.uid;
      
      allow update: if isAuthenticated() && isValidRequest(request.resource.data) && 
                    (resource.data.usuarioId == request.auth.uid || isAdmin()) &&
                    (request.resource.data.usuarioId == resource.data.usuarioId); // Prevent ownership change
      
      allow delete: if isAdmin() || (isOwner(resource.data.usuarioId) && resource.data.status == 'Pendente');
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.usuarioId == request.auth.uid;
      allow create: if isAuthenticated(); // Allow authenticated users to create notifications (e.g. students notifying admins)
      allow update: if isAuthenticated() && resource.data.usuarioId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lida']);
      allow delete: if isAuthenticated() && resource.data.usuarioId == request.auth.uid;
    }
  }
}
